## —— Linters et Code Quality ——————————————————————————————————

lint-php: ## Lint PHP avec PHP_CodeSniffer et WordPress Coding Standards
	@echo "🔍 Linting PHP avec WordPress Coding Standards..."
	./vendor/bin/phpcs --standard=$(THEME)/phpcs.xml --extensions=php --ignore="*/node_modules/*,*/vendor/*,*/public/*" $(THEME)

lint-php-fix: ## Auto-correction PHP avec PHP_CodeSniffer
	@echo "🔧 Auto-correction PHP..."
	./vendor/bin/phpcbf --standard=$(THEME)/phpcs.xml --extensions=php --ignore="*/node_modules/*,*/vendor/*,*/public/*" $(THEME)

lint-scss: ## Lint SCSS avec stylelint
	@echo "🎨 Linting SCSS..."
	cd $(THEME) && npx stylelint "resources/css/**/*.scss" --ignore-path .gitignore

lint-scss-fix: ## Auto-correction SCSS
	@echo "🔧 Auto-correction SCSS..."
	cd $(THEME) && npx stylelint "resources/css/**/*.scss" --fix --ignore-path .gitignore

lint-js: ## Lint JavaScript avec ESLint
	@echo "📜 Linting JavaScript..."
	cd $(THEME) && if find resources/js -type f -name "*.js" -print -quit | grep -q .; then npx eslint --ext .js resources/js --ignore-path .gitignore; else echo "(skip) aucun .js"; fi

lint-js-fix: ## Auto-correction JavaScript
	@echo "🔧 Auto-correction JavaScript..."
	cd $(THEME) && if find resources/js -type f -name "*.js" -print -quit | grep -q .; then npx eslint --ext .js resources/js --fix --ignore-path .gitignore; else echo "(skip) aucun .js"; fi

lint-ts: ## Lint TypeScript avec ESLint (principal)
	@echo "📜 Linting TypeScript..."
	cd $(THEME) && npx eslint --ext .ts,.tsx resources/js --ignore-path .gitignore

lint-ts-fix: ## Auto-correction TypeScript (principal)
	@echo "🔧 Auto-correction TypeScript..."
	cd $(THEME) && npx eslint --ext .ts,.tsx resources/js --fix --ignore-path .gitignore

lint-blade: ## Lint Blade avec blade-formatter (check)
	@echo "🧩 Linting Blade..."
	@cd $(THEME) && npx prettier --check "resources/views/**/*.blade.php" --ignore-path .gitignore || ( \
		echo "🔧 Format Blade auto" && \
		npx prettier --write "resources/views/**/*.blade.php" --ignore-path .gitignore && \
		npx prettier --check "resources/views/**/*.blade.php" --ignore-path .gitignore \
	)

format-js: ## Formatage JavaScript avec Prettier
	@echo "🎨 Formatage JavaScript..."
	cd $(THEME) && npx prettier --write "resources/js/**/*.js" --ignore-path .gitignore

format-ts: ## Formatage TypeScript avec Prettier
	@echo "🎨 Formatage TypeScript..."
	cd $(THEME) && npx prettier --write "resources/js/**/*.ts" "resources/js/**/*.tsx" --ignore-path .gitignore

format-all-js: ## Formatage de tous les fichiers JS/TS
	@echo "🎨 Formatage de tous les fichiers JS/TS..."
	cd $(THEME) && npx prettier --write "resources/js/**/*.{js,ts,tsx}" --ignore-path .gitignore

format-scss: ## Formatage SCSS avec Prettier
	@echo "🎨 Formatage SCSS..."
	cd $(THEME) && npx prettier --write "resources/css/**/*.scss" --ignore-path .gitignore

format-blade: ## Formatage Blade avec blade-formatter
	@echo "🎨 Formatage Blade..."
	cd $(THEME) && npx prettier --write "resources/views/**/*.blade.php" --ignore-path .gitignore

lint-all: ## Lance tous les linters
	@echo "🚀 Lancement de tous les linters..."
	make lint-php
	make lint-scss
	make lint-ts
	make lint-js
	make lint-blade

lint: ## Lint + format + sécurité + performance (thème uniquement)
	@echo "🚀 Lint global (thème) — lint, format, sécurité, performance"
	make format-all
	make lint-all
	make security-check
	make wp-security
	make wp-cache
	make wp-optimize

lint-all-fix: ## Auto-correction de tous les linters
	@echo "🔧 Auto-correction de tous les linters..."
	make lint-php-fix
	make lint-scss-fix
	make lint-ts-fix
	make lint-js-fix
	make format-blade

lint-fix: ## Corrige automatiquement (linters + formatage)
	@echo "🛠️  Auto-fix — linters + format (thème)"
	make lint-all-fix
	make format-all

format-all: ## Formatage de tous les fichiers
	@echo "🎨 Formatage de tous les fichiers..."
	make format-all-js
	make format-scss
	make format-blade

format: ## Alias — formatage JS/TS/SCSS du thème
	make format-all

## —— Sécurité et Audit ——————————————————————————————————

security-check: ## Vérification de sécurité avec Composer
	@echo "🔒 Vérification de sécurité Composer..."
	composer audit

wp-security: ## Vérification de sécurité WordPress
	@echo "🔒 Vérification de sécurité WordPress..."
	wp plugin list --status=active --format=table
	wp theme list --status=active --format=table
	@echo "⚠️  Vérifiez manuellement les plugins et thèmes actifs"

## —— Performance ——————————————————————————————————

wp-cache: ## Optimisation du cache WordPress
	@echo "⚡ Optimisation du cache..."
	wp cache flush
	wp rewrite flush
	wp transient delete --all

wp-optimize: ## Optimisation générale WordPress
	@echo "⚡ Optimisation générale..."
	wp db optimize
	wp db repair
	wp cache flush
	wp rewrite flush

