				echo "✅ Composant ajouté au template Blade"; \
				;; \
		esac; \
	else \
		echo "⚠️  Fichier Blade non trouvé: $$blade_file"; \
	fi; \
		echo "🎉 Composant $$component_name ajouté à la page $$page_title !"

